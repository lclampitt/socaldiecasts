# Supabase (required for auth + orders database)
# Sign up at https://supabase.com and create a project
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# EmailJS (required for contact form emails to logannc44@yahoo.com)
# Sign up at https://emailjs.com
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Stripe (required for real payment processing)
# Sign up at https://stripe.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
